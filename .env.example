# Build/deploy target identifier (public host or IP this instance serves)
BUILD_TARGET=xmine.example

# Database (LiteBans)
DATABASE_DRIVER=mysql
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=litebans_user
DATABASE_PASSWORD=password
DATABASE_NAME=litebans
TABLE_PREFIX=litebans_

# List endpoint behaviour
CONSOLE_ALIASES=CONSOLE,Console
INCLUDE_INACTIVE=true
INCLUDE_SILENT=true
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# ID obfuscation (OBFUSCATION_SECRET is required when OBFUSCATE_IDS=true)
OBFUSCATE_IDS=false
OBFUSCATION_SECRET=

# JWT validation (public key issued by Identity Service)
JWT_PUBLIC_KEY_PATH=/etc/xmine/identity-public-key.pem
JWT_ISSUER=xmine-identity

# Authority Service (permission checks)
AUTHORITY_API_URL=http://127.0.0.1:8080
AUTHORITY_CACHE_TTL=60s
INTERNAL_TOKEN=change-me-shared-secret
MOD_PERMISSION=web.litebans.view.all

# Punishment types exposed publicly (subset of: ban, mute, warning, kick)
PUBLIC_TYPES=ban

# HTTP & logging
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=text
